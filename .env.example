# Database
DATABASE_URL=file:./db/appforge.db

# NextAuth
AUTH_SECRET=replace-with-openssl-rand-hex-32
NEXTAUTH_URL=http://localhost:3000

# Token encryption (AES-256-GCM)
APP_ENCRYPTION_KEY=replace-with-openssl-rand-hex-32

# Optional: GitHub OAuth (leave blank to disable — credentials-only auth)
GITHUB_OAUTH_ID=
GITHUB_OAUTH_SECRET=

# Pullarao 1 (GLM-5.2) — server-side only, never exposed to the browser.
# Get a key at https://open.bigmodel.cn (or https://z.ai for international accounts)
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_MODEL=glm-5.2
# Optional — override the sub-models used by video/speech capabilities
GLM_VIDEO_MODEL=cogvideox-3
GLM_TTS_MODEL=cogtts
GLM_ASR_MODEL=glm-asr

# Concurrency limit on the shared GLM key — set this to match your actual
# plan's concurrency limit (check the bigmodel.cn console). Requests beyond
# this queue for up to 90s instead of failing outright.
GLM_MAX_CONCURRENT=3

# Vercel Sandbox (real build verification + live Next.js preview)
# In production on Vercel, this authenticates automatically via OIDC —
# nothing to set here. For local development, run `vercel link && vercel
# env pull` to get a dev token. See https://vercel.com/docs/sandbox
# Only needed for non-Vercel environments (e.g. external CI):
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=
# VERCEL_PROJECT_ID=
