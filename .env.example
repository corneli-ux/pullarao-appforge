# Database
DATABASE_URL=file:./db/appforge.db

# NextAuth
AUTH_SECRET=replace-with-openssl-rand-hex-32
NEXTAUTH_URL=http://localhost:3000

# Token encryption (AES-256-GCM)
APP_ENCRYPTION_KEY=replace-with-openssl-rand-hex-32

# Optional: GitHub OAuth (leave blank to disable — credentials-only auth)
GITHUB_OAUTH_ID=
GITHUB_OAUTH_SECRET=

# Pullarao 1 (GLM-5.2) — server-side only, never exposed to the browser.
# Get a key at https://open.bigmodel.cn (or https://z.ai for international accounts)
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_MODEL=glm-5.2
# Optional — override the sub-models used by video/speech capabilities
GLM_VIDEO_MODEL=cogvideox-3
GLM_TTS_MODEL=cogtts
GLM_ASR_MODEL=glm-asr
