# Database
DATABASE_URL=file:./db/appforge.db

# NextAuth
AUTH_SECRET=replace-with-openssl-rand-hex-32
NEXTAUTH_URL=http://localhost:3000

# Token encryption (AES-256-GCM)
APP_ENCRYPTION_KEY=replace-with-openssl-rand-hex-32

# Optional: GitHub OAuth (leave blank to disable — credentials-only auth)
GITHUB_OAUTH_ID=
GITHUB_OAUTH_SECRET=
